def add_contact(command=""):
    """Let the user add a new email contact by voice."""
    try:
        speak("What is the contact's name?")
        name = listen(timeout=10)
        if not name:
            speak("Sorry, I did not catch the name!")
            return
        name = name.strip().lower()

        speak(f"What is {name}'s email address? Please say it clearly.")
        email_raw = listen(timeout=15)
        if not email_raw:
            speak("Sorry, I did not catch the email address!")
            return

        # Clean up spoken email:
        # "john at gmail dot com" → "john@gmail.com"
        email = (email_raw.strip()
