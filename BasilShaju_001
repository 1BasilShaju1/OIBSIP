    if not setting:
        speak("What would you like to customize? Say my name, your name, voice, speed, city, or wake word.")
        resp    = listen(timeout=15)
        setting = resp.lower() if resp else ""

    setting = (setting or "").lower()

    # ── AI name ── (matches JSON key "ai_name" AND natural speech)
    if any(w in setting for w in ["your name", "ai name", "assistant name", "ai_name"]):
        if not new_value:
            speak(f"What would you like to call me instead of {SETTINGS['ai_name']}?")
            new_value = listen(timeout=10)
        if new_value:
            new_value             = new_value.strip().title()
            old_name              = SETTINGS["ai_name"]
            SETTINGS["ai_name"]   = new_value
            SETTINGS["wake_words"] = [
                f"hey {new_value.lower()}",
                f"hi {new_value.lower()}",
                new_value.lower(), "wake up"
            ]
            save_settings()
            speak(f"Done! You can now call me {new_value} instead of {old_name}!")
        else:
            speak("Sorry, I did not catch the new name!")

    # ── User name ── (matches JSON key "user_name" AND natural speech)
    elif any(w in setting for w in ["my name", "user name", "call me", "user_name"]):
        if not new_value:
            speak(f"What should I call you instead of {SETTINGS['user_name']}?")
            new_value = listen(timeout=10)
        if new_value:
            SETTINGS["user_name"] = new_value.strip().title()
            save_settings()
            speak(f"Got it! I will call you {SETTINGS['user_name']} from now on!")
        else:
            speak("Sorry, I did not catch your name!")

    # ── Voice ──
    elif "voice" in setting:
        engine = pyttsx3.init()
        voices = engine.getProperty('voices')
        engine.stop()
        voice_list = " ".join([f"Voice {i}: {v.name}." for i, v in enumerate(voices)])
        speak(f"Available voices: {voice_list} Which number?")
        resp = listen(timeout=10)
        num  = extract_number(resp or "")
        if num is not None and 0 <= num < len(voices):
            SETTINGS["voice_index"] = num
            save_settings()
            speak(f"Voice changed to number {num}!")
        else:
            speak("Sorry, I did not catch a valid voice number!")

    # ── Speed ── (matches JSON key "speed" AND natural speech)
    elif any(w in setting for w in ["speed", "rate", "faster", "slower"]):
        speak("Say slow, normal, or fast.")
        resp = (listen(timeout=10) or "").lower()
        rate = 120 if "slow" in resp else 190 if "fast" in resp else 150
        SETTINGS["voice_rate"] = rate
        save_settings()
        speak(f"Speed set to {rate}. How does this sound?")

    # ── Default city ── (matches JSON key "city" AND natural speech)
    elif any(w in setting for w in ["city", "location", "default city"]):
        if not new_value:
            speak("What city should I use as your default for weather?")
            new_value = listen(timeout=10)
        if new_value:
            SETTINGS["default_city"] = new_value.strip().title()
            save_settings()
            speak(f"Default city set to {SETTINGS['default_city']}!")
        else:
            speak("Sorry, I did not catch the city name!")

    # ── Wake word ── (matches JSON key "wake_word" AND natural speech)
    elif any(w in setting for w in ["wake word", "wake up word", "trigger word", "wake_word"]):
        if not new_value:
            speak("What new wake word would you like to add?")
            new_value = listen(timeout=10)
        if new_value:
            new_value = new_value.strip().lower()
            if new_value not in SETTINGS["wake_words"]:
                SETTINGS["wake_words"].append(new_value)
                save_settings()
                speak(f"Done! You can now say {new_value} to wake me up!")
            else:
                speak(f"{new_value} is already a wake word!")
        else:
            speak("Sorry, I did not catch the wake word!")

    # ── Show current settings ──
    elif any(w in setting for w in ["settings", "show", "what are", "current"]):
        speak(
            f"My name is {SETTINGS['ai_name']}. "
            f"I call you {SETTINGS['user_name']}. "
            f"Voice index is {SETTINGS['voice_index']}. "
            f"Speed is {SETTINGS['voice_rate']}. "
            f"Default city is {SETTINGS['default_city']}. "
            f"Wake words are {', '.join(SETTINGS['wake_words'])}."
        )

    else:
        speak("Sorry, I did not understand what to customize.")


