            alert_queue.put(
                f"Hey {SETTINGS['user_name']}! "
                f"Your {number} {unit} timer is done!"
            )

        threading.Thread(target=timer_thread, daemon=True).start()

    except Exception as e:
        speak("Sorry, I could not start that timer!")
        print(f"Timer error: {e}")


