                       "set reminder","remind me to","remind me"]:
            command = command.replace(phrase, "")
        command = command.strip()

        if "at" in command:
            parts         = command.split("at")
            task          = parts[0].strip() or None
            time_str      = parts[1].strip()
            if not task:
                speak("What would you like me to remind you about?")
                task = listen()
                if not task:
                    speak("Sorry I did not catch that!")
                    return
                task = task.replace("to", "").strip()
            reminder_time = parse_time_string(time_str)
        else:
            task = command.strip()
            if not task:
                speak("What would you like me to remind you about?")
                task = listen()
                if not task:
                    speak("Sorry I did not catch that!")
                    return
                task = task.replace("to", "").strip()
            speak(f"Sure! What time should I remind you to {task}?")
            time_response = listen()
            if not time_response:
                speak("Sorry I did not catch the time!")
                return
            time_str      = time_response.replace("at", "").strip()
