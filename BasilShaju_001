        for i, v in enumerate(voices):
            voice_list += f"Voice {i}: {v.name}. "

        speak(f"Available voices are: {voice_list} Which number would you like?")
        resp = listen(timeout=10)
        num  = extract_number(resp or "")

        if num is not None and 0 <= num < len(voices):
            SETTINGS["voice_index"] = num
            save_settings()
            speak(f"Voice changed! This is my new voice. Voice number {num}.")
        else:
            speak("Sorry, I did not catch a valid voice number!")

    # ── CHANGE SPEED ────────────────────────────────────────
    elif any(w in setting for w in ["speed","rate","faster","slower"]):
        speak(
            "What speed would you like? "
            "Say slow for 120, normal for 150, or fast for 190."
        )
        resp = listen(timeout=10)
        resp = (resp or "").lower()

        if "slow" in resp:
            rate = 120
        elif "fast" in resp:
            rate = 190
        elif "normal" in resp:
            rate = 150
        else:
            num = extract_number(resp)
            rate = num if num else 150

        SETTINGS["voice_rate"] = rate
        save_settings()
        speak(f"Speed set to {rate}. How does this sound?")

    # ── CHANGE DEFAULT CITY ─────────────────────────────────
    elif any(w in setting for w in ["city","location","home city","default city"]):
        if not new_value:
            speak("What city should I use as your default for weather?")
            new_value = listen(timeout=10)
        if new_value:
