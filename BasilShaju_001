def set_reminder(task, reminder_time):
    try:
        if not task:
            speak("What would you like me to remind you about?")
            task = listen(timeout=15)
            if not task:
                speak("Sorry, I did not catch that!")
                return
            task = task.replace("to","").strip()

        if not reminder_time:
            speak(f"What time should I remind you to {task}?")
            time_response = listen(timeout=15)
            if not time_response:
                speak("Sorry, I did not catch the time!")
                return
            reminder_time = time_response.replace("at","").strip()

        parsed = parse_time_string(reminder_time)
        if not parsed:
            speak("Sorry, I could not understand that time. Try saying 3 PM or 10 30 AM.")
            return

        reminders.append({"task": task, "time": parsed.lower()})
        speak(f"Reminder set! I will remind you to {task} at {parsed}.")
        print(f"✅ Reminder saved: {task} at {parsed}")

    except Exception as e:
        speak("Sorry, I could not set that reminder!")
        print("Reminder error:", e)


