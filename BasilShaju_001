# ============================================
#   WIKIPEDIA
# ============================================
def search_wikipedia(command):
    global last_query
    try:
        query = command.replace("who is",      "")
        query = query.replace("what is",       "")
        query = query.replace("what's",        "")
        query = query.replace("tell me about", "")
        query = query.replace("wikipedia",     "")
        query = query.replace("define",        "")
        query = query.strip()

        if not query:
            speak("What would you like to know about?")
            query = listen()
            if not query:
                speak("Sorry I did not catch that!")
                return

        last_query = query
        headers    = {'User-Agent': 'SkyAssistant/1.0 (student project)'}
        found      = False

        try:
            url      = f"https://en.wikipedia.org/api/rest_v1/page/summary/{query.replace(' ', '_')}"
            response = requests.get(url, headers=headers, timeout=5)
            data     = response.json()
            if "extract" in data and data["extract"] and data.get("type") != "disambiguation":
                summary       = data["extract"]
                sentences     = summary.split(". ")
                short_summary = ". ".join(sentences[:2])
                if not short_summary.endswith("."):
                    short_summary += "."
                speak(short_summary)
                found = True
        except Exception as e:
            logging.error(f"Wikipedia attempt 1: {e}")

        if not found:
            try:
                search_url = "https://en.wikipedia.org/w/api.php"
                params     = {"action": "query", "list": "search", "srsearch": query, "format": "json"}
                response   = requests.get(search_url, headers=headers, params=params, timeout=5)
                data       = response.json()
                results    = data["query"]["search"]
                if results:
                    best_title = results[0]["title"]
                    url2       = f"https://en.wikipedia.org/api/rest_v1/page/summary/{best_title.replace(' ', '_')}"
                    response2  = requests.get(url2, headers=headers, timeout=5)
                    data2      = response2.json()
                    if "extract" in data2 and data2["extract"]:
                        summary       = data2["extract"]
                        sentences     = summary.split(". ")
                        short_summary = ". ".join(sentences[:2])
                        if not short_summary.endswith("."):
                            short_summary += "."
                        speak(short_summary)
                        found = True
            except Exception as e:
                logging.error(f"Wikipedia attempt 2: {e}")

        if not found:
            speak("Nothing found. Opening Chrome.")
            open_chrome_search(query)

    except Exception as e:
        speak("Sorry something went wrong!")
        logging.error(f"search_wikipedia() error: {e}")

# ============================================
#   TIME PARSER
# ============================================
def parse_time_string(time_str):
    try:
        time_str = time_str.strip().lower()
        period   = "PM" if ("p.m" in time_str or " pm" in time_str) else "AM"
        for rep in ["p.m.", "a.m.", "pm", "am", "p m", "a m"]:
            time_str = time_str.replace(rep, "")
        time_str = time_str.replace(".", "").replace(":", " ").strip()
        parts    = time_str.split()
        if not parts:
            return None
        if len(parts) == 1:
            num = parts[0]
            if len(num) <= 2:
                hour, minute = num.zfill(2), "00"
            elif len(num) == 3:
                hour, minute = num[0].zfill(2), num[1:]
            elif len(num) == 4:
                hour, minute = num[:2], num[2:]
            else:
                return None
        else:
            hour, minute = parts[0].zfill(2), parts[1].zfill(2)
        return f"{hour}:{minute} {period}"
    except Exception as e:
        logging.error(f"parse_time_string() error: {e}")
        return None

