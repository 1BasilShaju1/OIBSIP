                speak(f"Note {last_shown_note+1}: {lines[last_shown_note]}")
            else:
                speak("I haven't read a note yet!")
        elif any(w in q for w in ["previous","before"]):
            if last_shown_note is not None and last_shown_note > 0:
                last_shown_note -= 1
                speak(f"Note {last_shown_note+1}: {lines[last_shown_note]}")
            else:
                speak("That is the oldest note!")
        elif any(w in q for w in ["next","after"]):
            if last_shown_note is not None and last_shown_note < total - 1:
                last_shown_note += 1
                speak(f"Note {last_shown_note+1}: {lines[last_shown_note]}")
            else:
                speak("That is the latest note!")
        elif any(w in q for w in ["all","everything","five"]):
            count = min(5, total)
            speak(f"Here are your last {count} notes.")
            for i, line in enumerate(lines[-count:]):
                speak(f"Note {total-count+i+1}: {line}")
            last_shown_note = total - 1
        else:
            num = extract_number(q)
            if num is not None and 1 <= num <= total:
                last_shown_note = num - 1
                speak(f"Note {num}: {lines[last_shown_note]}")
            else:
                speak(f"You have {total} note{'s' if total != 1 else ''}.")
                last_shown_note = total - 1
                speak(f"Your latest note: {lines[last_shown_note]}")
                if total > 1:
                    speak("Say next, previous, or a number to browse.")

    except Exception as e:
        speak("Sorry, I could not read your notes!")
        print(f"Notes error: {e}")


