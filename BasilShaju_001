            try:
                os.startfile("wmplayer.exe")
            except Exception:
                speak("Media player not found!")

        elif "excel" in app:
            speak("Opening Excel!")
            try:
                os.startfile("excel.exe")
            except Exception:
                speak("Excel not found!")

        elif "word" in app:
            speak("Opening Word!")
            try:
                os.startfile("winword.exe")
            except Exception:
                speak("Word not found!")

        elif any(w in app for w in ["task manager", "taskmgr"]):
            speak("Opening Task Manager!")
            os.startfile("taskmgr.exe")

        elif "spotify" in app:
            speak("Opening Spotify!")
            try:
                os.startfile("spotify.exe")
            except Exception:
                webbrowser.open("https://open.spotify.com")

        elif any(w in app for w in ["vs code", "vscode", "visual studio code"]):
            speak("Opening VS Code!")
            try:
                subprocess.Popen(["code"], shell=True)
            except Exception:
                speak("VS Code not found!")

        elif "paint" in app:
            speak("Opening Paint!")
