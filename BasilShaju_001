def customize(setting, new_value, command=""):
    """
    Let the user change AI name, their own name,
    voice, speed, or wake words — all by voice!
    """
    global SETTINGS

    cmd = (command or "").lower()

    # Ask what to change if Gemini didn't detect it
    if not setting:
        speak(
            "What would you like to customize? "
            "You can say: my name, your name, voice, speed, or wake word."
        )
        resp    = listen(timeout=15)
        setting = resp.lower() if resp else ""

    # ── CHANGE AI NAME ──────────────────────────────────────
    if any(w in setting for w in ["your name","ai name","assistant name"]):
        if not new_value:
            speak(f"What would you like to call me instead of {SETTINGS['ai_name']}?")
            new_value = listen(timeout=10)
        if new_value:
            new_value = new_value.strip().title()
            old_name  = SETTINGS["ai_name"]
            SETTINGS["ai_name"] = new_value
            # Update wake words to use new name automatically
            SETTINGS["wake_words"] = [
                f"hey {new_value.lower()}",
                f"hi {new_value.lower()}",
                new_value.lower(),
                "wake up"
            ]
            save_settings()
            speak(f"Done! You can now call me {new_value} instead of {old_name}!")
        else:
            speak("Sorry, I did not catch the new name!")

    # ── CHANGE USER NAME ────────────────────────────────────
    elif any(w in setting for w in ["my name","user name","your name is wrong","call me"]):
        if not new_value:
            speak(f"What should I call you instead of {SETTINGS['user_name']}?")
            new_value = listen(timeout=10)
        if new_value:
            new_value = new_value.strip().title()
            SETTINGS["user_name"] = new_value
            save_settings()
            speak(f"Got it! I will call you {new_value} from now on!")
        else:
            speak("Sorry, I did not catch your name!")

    # ── CHANGE VOICE ────────────────────────────────────────
    elif "voice" in setting:
        engine = pyttsx3.init()
        voices = engine.getProperty('voices')
        engine.stop()

        # List available voices
