    # ------------------------------------------
    #   LOG A LINE TO TRANSCRIPT
    # ------------------------------------------
    def log(self, role, text):
        self.root.after(0, self._insert_line, role, text)

    def _insert_line(self, role, text):
        self.transcript.config(state="normal")

        ts = datetime.datetime.now().strftime("%H:%M:%S")

        if role == "you":
            prefix = f"[{ts}]  YOU  →  "
        elif role == "sky":
            prefix = f"[{ts}]  SKY  →  "
        elif role == "warn":
            prefix = f"[{ts}]  !    →  "
        else:
            prefix = f"[{ts}]       →  "

        self.transcript.insert("end", prefix, role)
        self.transcript.insert("end", text + "\n", role)
        self.transcript.see("end")
        self.transcript.config(state="disabled")

    def _clear_transcript(self):
        self.transcript.config(state="normal")
        self.transcript.delete("1.0", "end")
        self.transcript.config(state="disabled")

    # ------------------------------------------
    #   STATUS + MIC INDICATOR
    # ------------------------------------------
    def set_status(self, state):
        # state: "sleeping" | "listening" | "speaking" | "thinking"
        colours = {
            "sleeping":  ("#555566", "#1e1e2e", "#1e1e2e"),
            "listening": ("#4ecdc4", "#0f2f2d", "#4ecdc4"),
            "speaking":  ("#7c6fff", "#1a1a2e", "#7c6fff"),
            "thinking":  ("#e9c46a", "#2a200a", "#e9c46a"),
        }
        fg, bg, dot = colours.get(state, colours["sleeping"])
        self.root.after(0, lambda: [
            self.status_var.set(state),
            self.status_label.config(fg=fg, bg=bg),
            self.mic_dot.config(fg=dot),
            self.mic_label.config(
                text={
                    "sleeping":  "say  \"hey sky\"  to wake me up",
                    "listening": "listening...",
                    "speaking":  "speaking...",
                    "thinking":  "processing...",
                }.get(state, "")
            )
        ])

    def update_reminders(self):
        count = len(reminders)
        label = f"{count} reminder{'s' if count != 1 else ''}"
        self.root.after(0, lambda: self.reminder_var.set(label))

    # ------------------------------------------
    #   CLOCK
    # ------------------------------------------
    def _tick_clock(self):
        now = datetime.datetime.now().strftime("%A  %d %b  %H:%M:%S")
        self.clock_var.set(now)
        self.root.after(1000, self._tick_clock)


# ============================================
#   SPEAK
# ============================================
def speak(text):
    with speak_lock:
        if gui:
            gui.log("sky", text)
            gui.set_status("speaking")
        print("🤖 Sky:", text)
        try:
            engine = pyttsx3.init()
            voices = engine.getProperty('voices')
            engine.setProperty('voice', voices[2].id if len(voices) > 2 else voices[0].id)
            engine.setProperty('rate', 150)
            engine.setProperty('volume', 1.0)
            engine.say(text)
            engine.runAndWait()
            engine.stop()
            time.sleep(0.3)
        except Exception as e:
            logging.error(f"speak() error: {e}")
        finally:
            if gui:
                gui.set_status("listening" if gui.is_awake else "sleeping")

# ============================================
#   LISTEN
# ============================================
def listen(timeout=1000):
    recognizer = sr.Recognizer()
    with sr.Microphone() as source:
        recognizer.adjust_for_ambient_noise(source, duration=1)
        recognizer.pause_threshold = 1
        try:
            audio = recognizer.listen(source, timeout=timeout)
            text  = recognizer.recognize_google(audio)
            print("✅ You said:", text)
            if gui:
                gui.log("you", text)
            return text.lower()
        except sr.WaitTimeoutError:
            return ""
        except sr.UnknownValueError:
            return ""
        except sr.RequestError:
            alert_queue.put("Internet connection problem!")
            return ""

