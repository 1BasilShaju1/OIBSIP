def run_assistant():
    global last_query, SETTINGS

    # Start reminder checker
    threading.Thread(target=check_reminders, daemon=True).start()

    ai_name   = SETTINGS["ai_name"]
    user_name = SETTINGS["user_name"]

    is_awake      = False
    last_activity = time.time()

    while True:
        # Refresh from settings in case user changed them
        ai_name      = SETTINGS["ai_name"]
        user_name    = SETTINGS["user_name"]
        wake_words   = SETTINGS["wake_words"]
        sleep_timeout = SETTINGS["sleep_timeout"]

        check_alerts()

        # ── SLEEP MODE ───────────────────────────────────────
        if not is_awake:
            print(f"😴 {ai_name} sleeping...")
            command = listen()
            check_alerts()
            if not command:
                continue

            woke_up           = False
            remaining_command = ""
            for wake in wake_words:
                if wake in command:
                    woke_up           = True
                    remaining_command = command.replace(wake, "").strip()
                    break

            if not woke_up:
                continue

            is_awake      = True
            last_activity = time.time()
            speak(f"Yes {user_name}!")
            print(f"👀 {ai_name} is awake")

            if remaining_command:
                command = remaining_command
            else:
                command = listen(timeout=15)
                check_alerts()
                if not command:
                    continue
                last_activity = time.time()

        # ── AWAKE MODE ───────────────────────────────────────
        else:
            print(f"👀 {ai_name} listening...")
            command = listen(timeout=15)
            check_alerts()

            if not command:
                if time.time() - last_activity > sleep_timeout:
                    is_awake = False
                    print(f"😴 {ai_name} went to sleep — inactivity")
                continue

            last_activity = time.time()

        # ── SEND TO GEMINI ───────────────────────────────────
        print(f"🗣️  Processing: '{command}'")
        understood = understand_command(command)
        intent     = understood.get("intent", "unknown")
        print(f"✅ Intent: {intent}")

        # ── EXECUTE INTENT ───────────────────────────────────

        if intent == "greeting":
            speak(f"Hello {user_name}! Great to hear from you!")

        elif intent == "how_are_you":
            speak("I am doing great! Thank you for asking!")

        elif intent == "name":
            speak(
                f"My name is {ai_name}, your personal AI voice assistant "
                "powered by Google Gemini!"
            )

        elif intent == "time_and_date":
            speak(
                "Today is "
                + datetime.datetime.now().strftime("%B %d %Y")
                + " and the time is "
                + datetime.datetime.now().strftime("%I:%M %p") + "."
            )

        elif intent == "time":
            speak("The current time is "
                  + datetime.datetime.now().strftime("%I:%M %p") + ".")

        elif intent == "date":
            speak("Today is "
                  + datetime.datetime.now().strftime("%B %d %Y") + ".")

        elif intent == "reminder_set":
            set_reminder(
                understood.get("task"),
                understood.get("time")
            )

        elif intent == "reminder_show":
            show_reminders()

        elif intent == "timer":
            set_timer(understood.get("duration"))

        elif intent == "note_take":
            take_note(understood.get("task") or command)

        elif intent == "note_show":
            show_notes()

        elif intent == "send_email":
            send_email(understood.get("contact"))

        elif intent == "add_contact":
            add_contact(command)

        elif intent == "calculate":
            calculate(understood.get("expression") or command)

        elif intent == "weather":
            get_weather(understood.get("city"))

        elif intent == "wikipedia":
            search_wikipedia(understood.get("topic") or command)

        elif intent == "search":
            topic = understood.get("topic") or command
            speak(f"Searching for {topic}.")
            open_chrome_search(topic)
            last_query = topic

        elif intent == "open_app":
            open_app(understood.get("app") or command)

        elif intent == "volume_control":
            control_volume(
                understood.get("task") or command,
                understood.get("action"),
                understood.get("value")
            )

        elif intent == "brightness_control":
            control_brightness(
                understood.get("task") or command,
                understood.get("action"),
                understood.get("value")
            )

        elif intent == "change":
            customize(
                understood.get("setting"),
                understood.get("new_value"),
                command
            )

        elif intent == "joke":
            jokes = [
                "Why do programmers prefer dark mode? Because light attracts bugs!",
                "Why did the computer go to the doctor? Because it had a virus!",
                "What do you call a computer that sings? A Dell!",
                "Why do Java developers wear glasses? Because they don't C sharp!",
                "How many programmers to change a light bulb? None — that is a hardware problem!",
                "Why was the computer cold? It left its Windows open!",
            ]
            speak(random.choice(jokes))

        elif intent == "small_talk":
            reply = understood.get("reply") or "That is interesting! Tell me more."
            speak(reply)

        elif intent == "sleep":
            speak(f"Okay, going to sleep. Goodbye {user_name}!")
            is_awake = False

        else:
            speak(
                f"I heard: {command}. "
                "I am not sure how to help with that yet!"
            )

        check_alerts()


