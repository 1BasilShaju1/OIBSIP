def control_brightness(command, action=None, value=None):
    if not BRIGHTNESS_AVAILABLE:
        speak("Sorry, brightness control is not available on this display.")
        return
    try:
        current = sbc.get_brightness()[0]
        cmd     = (command or "").lower()

        if not action:
            if "set" in cmd or "to" in cmd:                                          action = "set"
            elif any(w in cmd for w in ["up","increase","raise","brighter","higher"]): action = "increase"
            elif any(w in cmd for w in ["down","decrease","lower","dimmer","dim"]):    action = "decrease"
            elif "max" in cmd or "maximum" in cmd or "full" in cmd:                   action = "max"
            elif "min" in cmd or "minimum" in cmd:                                    action = "min"
            elif any(w in cmd for w in ["what","check","current"]):                   action = "check"
            else:                                                                      action = "check"

        if action == "set":
            number = value or extract_number(cmd)
            if number is None:
                speak("What brightness level? Say a number between 0 and 100.")
                resp   = listen(timeout=10)
                number = extract_number(resp) or 70
            number = max(0, min(100, int(number)))
            sbc.set_brightness(number)
            speak(f"Brightness set to {number} percent!")

        elif action == "increase":
            number  = value or extract_number(cmd) or 10
            new_val = min(100, current + int(number))
            sbc.set_brightness(new_val)
            speak(f"Brightness increased to {new_val} percent!")

        elif action == "decrease":
            number  = value or extract_number(cmd) or 10
            new_val = max(10, current - int(number))
            sbc.set_brightness(new_val)
            speak(f"Brightness decreased to {new_val} percent!")

        elif action == "max":
            sbc.set_brightness(100)
            speak("Brightness set to maximum!")

        elif action == "min":
            sbc.set_brightness(10)
            speak("Brightness set to minimum!")

        elif action == "check":
            speak(f"Current brightness is {current} percent.")

    except Exception as e:
        speak("Sorry, I could not control the brightness!")
        print("Brightness error:", e)


