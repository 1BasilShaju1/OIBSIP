def search_wikipedia(topic):
    global last_query
    try:
        query = (topic or "").strip()
        for phrase in ["who is","what is","what's","tell me about",
                       "wikipedia","define"]:
            query = query.replace(phrase, "").strip()

        if not query:
            speak("What would you like to know about?")
            query = listen(timeout=15)
            if not query:
                speak("Sorry, I did not catch that!")
                return

        last_query = query
        headers    = {'User-Agent': 'SkyAssistant/1.0 (student project)'}
        found      = False

        # Attempt 1 — direct lookup
        try:
            url      = ("https://en.wikipedia.org/api/rest_v1/page/summary/"
                        + query.replace(" ", "_"))
            response = req.get(url, headers=headers, timeout=5)
            data     = response.json()
            if ("extract" in data and data["extract"]
                    and data.get("type") != "disambiguation"):
                summary = data["extract"]
                short   = ". ".join(summary.split(". ")[:2])
                if not short.endswith("."): short += "."
                speak(short)
                found = True
        except Exception:
            pass

        # Attempt 2 — search for closest title
        if not found:
            try:
                params   = {"action":"query","list":"search",
                            "srsearch":query,"format":"json"}
                r2       = req.get("https://en.wikipedia.org/w/api.php",
                                   headers=headers, params=params, timeout=5)
                results  = r2.json()["query"]["search"]
                if results:
                    best    = results[0]["title"]
                    url2    = ("https://en.wikipedia.org/api/rest_v1/page/summary/"
                               + best.replace(" ","_"))
                    r3      = req.get(url2, headers=headers, timeout=5)
                    data2   = r3.json()
                    if "extract" in data2 and data2["extract"]:
                        summary = data2["extract"]
                        short   = ". ".join(summary.split(". ")[:2])
                        if not short.endswith("."): short += "."
                        speak(short)
                        found = True
            except Exception:
                pass

        if not found:
            speak("I could not find that on Wikipedia. Opening Chrome.")
            open_chrome_search(query)

    except Exception as e:
        speak("Sorry, something went wrong with the search!")
        print("Wikipedia error:", e)


