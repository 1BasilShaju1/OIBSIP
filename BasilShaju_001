def answer_question(query):
    global last_query
    try:
        q = strip_question_prefixes(query)
        if not q:
            speak("What would you like to know about?")
            q = listen(timeout=15)
            if not q:
                speak("Sorry, I did not catch that!")
                return

        last_query = q
        print(f"🔍 Question: '{q}'")

        # ── Step 1:  Groq ──
        answer = ask_groq(q)
        if answer:
            speak(answer)
            return

        # ── Step 2: GROQ fallback ──
        print("⚠️  GROQ failed, trying NVIDIA...")
        answer = ask_nvidia(q)
        if answer:
            speak(answer)
            return

        # ── Step 3: Both failed → open Chrome ──
        speak(f"Sorry, I could not find a good answer. Opening Chrome for {q}.")
        open_chrome_search(q)

    except Exception as e:
        speak("Sorry, something went wrong!")
        print(f"Answer error: {e}")


