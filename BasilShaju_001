def set_timer(command):
    try:
        for phrase in ["set a timer for","start timer for","set timer for",
                       "set a timer","set timer","timer for"]:
            command = command.replace(phrase, "")
        command = command.strip()
        parts   = command.split()
        number  = int(parts[0])
        if "second" in command:
            total_seconds, unit = number, "seconds"
        elif "minute" in command:
            total_seconds, unit = number * 60, "minutes"
        elif "hour" in command:
            total_seconds, unit = number * 3600, "hours"
        else:
            speak("Please say seconds minutes or hours!")
            return
        speak(f"Timer started for {number} {unit}!")
        if gui:
            gui.log("info", f"Timer: {number} {unit}")
        def timer_thread():
            time.sleep(total_seconds)
            alert_queue.put(f"Time is up! Your {number} {unit} timer is done!")
        threading.Thread(target=timer_thread, daemon=True).start()
    except Exception as e:
        speak("Sorry I could not set that timer!")
        logging.error(f"set_timer() error: {e}")

# ============================================
#   WORD NUMBER CONVERTER
# ============================================
def convert_word_numbers(text):
    operators = ["plus","minus","times","into","multiplied by","divided by","to the power of"]
    tokens    = re.split(
        r'(\bplus\b|\bminus\b|\btimes\b|\binto\b|\bmultiplied by\b|\bdivided by\b|\bto the power of\b)',
        text
    )
    result = []
    for token in tokens:
        token = token.strip()
        if not token:
            continue
        if token in operators:
            result.append(token)
        else:
            try:
                result.append(str(w2n.word_to_num(token)))
            except:
                result.append(token)
    return " ".join(result)

# ============================================
#   MATH DETECTION
# ============================================
MATH_WORDS = [
    "plus","minus","times","divided","multiplied","into","power",
    "root","percent","factorial","sine","cosine","tangent","log","pi",
    "+","-","*","/"
]
WORD_NUMS = [
    "zero","one","two","three","four","five","six","seven","eight","nine","ten",
    "eleven","twelve","thirteen","fourteen","fifteen","sixteen","seventeen",
    "eighteen","nineteen","twenty","thirty","forty","fifty","sixty","seventy",
    "eighty","ninety","hundred","thousand","million"
]

def is_math_question(command):
    has_math   = any(w in command for w in MATH_WORDS)
    has_digit  = any(c.isdigit() for c in command)
    has_wordnum= any(w in command for w in WORD_NUMS)
    return has_math and (has_digit or has_wordnum)

# ============================================
#   CALCULATOR
# ============================================
def calculate(command):
    try:
        expression = command.replace("calculate","").replace("what's","") \
                            .replace("what is","").replace("the","").strip()
        expression = convert_word_numbers(expression)

        if expression == "pi" or "value of pi" in expression:
            speak(f"Pi is approximately {round(math.pi, 5)}")
            return
        if "square root of" in expression:
            n = float(expression.replace("square root of","").strip())
            speak(f"Square root of {int(n)} is {round(math.sqrt(n),4)}")
            return
        if "cube root of" in expression:
            n = float(expression.replace("cube root of","").strip())
            speak(f"Cube root of {int(n)} is {round(n**(1/3),4)}")
            return
        if "percent of" in expression:
            parts   = expression.replace("percent of","SPLIT").split("SPLIT")
            percent = float(parts[0].strip())
            total   = float(parts[1].strip())
            speak(f"{percent} percent of {total} is {round((percent/100)*total,2)}")
            return
        if "factorial of" in expression:
            n = int(expression.replace("factorial of","").strip())
            speak(f"Factorial of {n} is {math.factorial(n)}")
            return
        if "sine of" in expression:
            a = float(expression.replace("sine of","").strip())
            speak(f"Sine of {a} degrees is {round(math.sin(math.radians(a)),4)}")
            return
        if "cosine of" in expression:
            a = float(expression.replace("cosine of","").strip())
            speak(f"Cosine of {a} degrees is {round(math.cos(math.radians(a)),4)}")
            return
        if "tangent of" in expression:
            a = float(expression.replace("tangent of","").strip())
            speak(f"Tangent of {a} degrees is {round(math.tan(math.radians(a)),4)}")
            return
        if "natural log of" in expression:
            n = float(expression.replace("natural log of","").strip())
            speak(f"Natural log of {n} is {round(math.log(n),4)}")
            return
        if "log of" in expression:
            n = float(expression.replace("log of","").strip())
            speak(f"Log of {n} is {round(math.log10(n),4)}")
            return

        expression = expression.replace("plus","+").replace("minus","-") \
                               .replace("multiplied by","*").replace("multiply by","*") \
                               .replace("times","*").replace("into","*") \
                               .replace("divided by","/").replace("divide by","/") \
                               .replace("to the power of","**").replace("to the power","**") \
                               .replace("power","**").replace(" by","")

        result = round(eval(expression), 4)
        speak(f"The answer is {result}")

    except ZeroDivisionError:
        speak("Sorry you cannot divide by zero!")
    except Exception as e:
        speak("Sorry I could not calculate that!")
        logging.error(f"calculate() error: {e}")

