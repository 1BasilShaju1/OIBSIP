def speak(text):
    with speak_lock:
        print(f"🤖 {SETTINGS['ai_name']}:", text)
        try:
            engine = pyttsx3.init()
            voices = engine.getProperty('voices')
            idx    = SETTINGS.get("voice_index", 2)
            if idx < len(voices):
                engine.setProperty('voice', voices[idx].id)
            engine.setProperty('rate',   SETTINGS.get("voice_rate", 150))
            engine.setProperty('volume', 1.0)
            engine.say(text)
            engine.runAndWait()
            engine.stop()
            time.sleep(0.1)
        except Exception as e:
            print("Speak error:", e)


