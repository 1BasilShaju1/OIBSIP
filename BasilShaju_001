def control_volume(command, action=None, value=None):
    try:
        devices   = AudioUtilities.GetSpeakers()
        interface = devices.Activate(IAudioEndpointVolume._iid_, CLSCTX_ALL, None)
        volume    = cast(interface, POINTER(IAudioEndpointVolume))

        current_vol = round(volume.GetMasterVolumeLevelScalar() * 100)
        cmd         = (command or "").lower()

        # Determine action from command if Gemini didn't extract it
        if not action:
            if "mute" in cmd and "unmute" not in cmd: action = "mute"
            elif "unmute" in cmd:                      action = "unmute"
            elif "set" in cmd or "to" in cmd:          action = "set"
            elif any(w in cmd for w in ["up","increase","raise","louder","higher"]): action = "increase"
            elif any(w in cmd for w in ["down","decrease","lower","quieter"]):       action = "decrease"
            elif any(w in cmd for w in ["what","check","current"]):                  action = "check"
            else:                                                                     action = "check"

        if action == "mute":
            volume.SetMute(1, None)
            speak("PC muted!")

        elif action == "unmute":
            volume.SetMute(0, None)
            speak("PC unmuted!")

        elif action == "set":
            number = value or extract_number(cmd)
            if number is None:
                speak("What volume level? Say a number between 0 and 100.")
                resp = listen(timeout=10)
                number = extract_number(resp) or 50
            number = max(0, min(100, int(number)))
            volume.SetMasterVolumeLevelScalar(number / 100, None)
            speak(f"Volume set to {number} percent!")

        elif action == "increase":
            number  = value or extract_number(cmd) or 10
            new_vol = min(100, current_vol + int(number))
            volume.SetMasterVolumeLevelScalar(new_vol / 100, None)
            speak(f"Volume increased to {new_vol} percent!")

        elif action == "decrease":
            number  = value or extract_number(cmd) or 10
            new_vol = max(0, current_vol - int(number))
            volume.SetMasterVolumeLevelScalar(new_vol / 100, None)
            speak(f"Volume decreased to {new_vol} percent!")

        elif action == "check":
            speak(f"Current volume is {current_vol} percent.")

    except Exception as e:
        speak("Sorry, I could not control the volume!")
        print("Volume error:", e)


