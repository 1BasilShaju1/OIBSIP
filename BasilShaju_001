def set_timer(duration_str):
    try:
        if not duration_str or not duration_str.strip():
            speak("How long should I set the timer for?")
            duration_str = listen(timeout=15)
            if not duration_str:
                speak("Sorry, I did not catch the duration!")
                return

        duration_text = duration_str.lower().strip()
        number        = extract_number(duration_text)

        if number is None:
            speak("Sorry, I could not find a number. Try saying 5 minutes or ten seconds.")
            return

        if "second" in duration_text:
            total_seconds = number
            unit          = "second" if number == 1 else "seconds"
        elif "minute" in duration_text:
            total_seconds = number * 60
            unit          = "minute" if number == 1 else "minutes"
        elif "hour" in duration_text:
            total_seconds = number * 3600
            unit          = "hour" if number == 1 else "hours"
        else:
            speak("Please say seconds, minutes, or hours.")
            return

        speak(f"Timer started for {number} {unit}!")

        def timer_thread():
            time.sleep(total_seconds)
            alert_queue.put(
                f"Hey {SETTINGS['user_name']}! "
                f"Time is up! Your {number} {unit} timer is done!"
            )

        threading.Thread(target=timer_thread, daemon=True).start()

    except Exception as e:
        speak("Sorry, I could not start that timer!")
        print("Timer error:", e)


