        data     = response.json()
        if data["cod"] == 200:
            temp       = round(data["main"]["temp"])
            feels_like = round(data["main"]["feels_like"])
            condition  = data["weather"][0]["description"]
            humidity   = data["main"]["humidity"]
            city_name  = data["name"]
            heat = (
                "It is very hot outside, stay hydrated!" if temp >= 35 else
                "It is warm outside."                    if temp >= 28 else
                "The weather is quite pleasant!"         if temp >= 20 else
                "It is a bit cool outside!"
            )
            speak(
                f"Weather for {city_name}: {temp} degrees, feels like {feels_like}. "
                f"Sky: {condition}. Humidity {humidity} percent. {heat}"
            )
        else:
            speak("Sorry I could not find weather for " + city)
    except Exception as e:
        speak("Sorry I could not get the weather right now!")
        logging.error(f"get_weather() error: {e}")

# ============================================
#   CONSTANTS
# ============================================
WAKE_WORDS    = ["hey sky", "hi sky", "sky", "wake up"]
SLEEP_TIMEOUT = 600

# ============================================
#   ASSISTANT LOOP — runs in background thread
# ============================================
def run_assistant():
    global last_query

    threading.Thread(target=check_reminders, daemon=True).start()

    is_awake      = False
    last_activity = time.time()

    while True:
        check_alerts()

        # ── SLEEP MODE ───────────────────────
        if not is_awake:
            if gui:
                gui.set_status("sleeping")
                gui.is_awake = False
            command = listen()
            check_alerts()
            if not command:
                continue

            woke_up           = False
            remaining_command = ""
            for wake in WAKE_WORDS:
                if wake in command:
                    woke_up           = True
                    remaining_command = command.replace(wake, "").strip()
                    break

            if not woke_up:
                continue

            is_awake      = True
            last_activity = time.time()
            if gui:
                gui.set_status("listening")
                gui.is_awake = True
            speak("Yes Boss")

            if remaining_command:
                command = remaining_command
            else:
                command = listen(timeout=15)
                check_alerts()
                if not command:
                    continue
                last_activity = time.time()

        # ── AWAKE MODE ───────────────────────
        else:
            if gui:
                gui.set_status("listening")
            command = listen(timeout=15)
            check_alerts()

            if not command:
                if time.time() - last_activity > SLEEP_TIMEOUT:
                    is_awake = False
                    if gui:
                        gui.log("info", "Going to sleep after inactivity.")
                continue

            last_activity = time.time()

        # ── PROCESS ──────────────────────────
        if gui:
            gui.set_status("thinking")

        if "hello" in command or "hi" in command:
            speak("Hello there! Great to hear from you!")

        elif "how are you" in command:
            speak("I am doing great! Thank you for asking!")

        elif "your name" in command:
            speak("My name is Sky, your personal voice assistant!")

        elif "time" in command and "date" in command:
            speak("Today is " + datetime.datetime.now().strftime("%B %d %Y") +
                  " and the time is " + datetime.datetime.now().strftime("%I:%M %p"))

        elif "time" in command and "timer" not in command:
            speak("The current time is " + datetime.datetime.now().strftime("%I:%M %p"))

        elif "date" in command:
            speak("Today is " + datetime.datetime.now().strftime("%B %d %Y"))

        elif ("show" in command or "my" in command or "list" in command) and "reminder" in command:
            show_reminders()

        elif "reminder" in command or "remind me" in command:
            set_reminder(command)

        elif "timer" in command and "reminder" not in command:
            set_timer(command)

        elif ("show" in command or "read" in command or "my notes" in command) and "note" in command:
            show_notes()

        elif any(p in command for p in ["take a note","make a note","note down","save note"]):
            take_note(command)

        elif "calculate" in command or is_math_question(command):
            calculate(command)

        elif "what is" in command or "what's" in command:
            search_wikipedia(command)

        elif "search" in command and "it" in command and ("google" in command or "chrome" in command):
            if last_query:
                speak(f"Searching for {last_query}")
                open_chrome_search(last_query)
            else:
                speak("I don't have a previous topic to search for!")

        elif "search" in command:
            query = command.split("search for")[-1].strip() if "search for" in command \
                    else command.split("search")[-1].strip()
            speak("Searching for " + query)
            open_chrome_search(query)
            last_query = query

        elif any(p in command for p in ["who is","tell me about","wikipedia","define"]):
            search_wikipedia(command)

        elif "weather" in command:
            city = command.split("in")[-1].strip() if "in" in command else "Thrissur"
            get_weather(city)

        elif "open" in command:
            open_app(command)

        elif "joke" in command:
            jokes = [
                "Why do programmers prefer dark mode? Because light attracts bugs!",
                "Why did the computer go to the doctor? Because it had a virus!",
                "What do you call a computer that sings? A Dell!"
            ]
            speak(random.choice(jokes))

        elif "go to sleep" in command or "bye" in command or "exit" in command:
            speak("Okay, going to sleep.")
            is_awake = False

        else:
            speak("I heard " + command + ". I am still learning new commands!")

        check_alerts()


# ============================================
#   LAUNCH
# ============================================
if __name__ == "__main__":
    root = tk.Tk()
    gui  = SkyDashboard(root)

    # Run assistant in background thread
    assistant_thread = threading.Thread(target=run_assistant, daemon=True)
    assistant_thread.start()

    root.mainloop()
