def send_email(contact_name):
    try:
        recipient_email = None
        recipient_name  = None
        contacts        = SETTINGS.get("contacts", {})

        if contact_name:
            for name, address in contacts.items():
                if name in contact_name.lower():
                    recipient_name  = name
                    recipient_email = address
                    break

        if not recipient_email:
            speak("Who would you like to send the email to?")
            spoken_name = listen(timeout=15)
            if not spoken_name:
                speak("Sorry, I did not catch that!")
                return
            for name, address in contacts.items():
                if name in spoken_name.lower():
                    recipient_name  = name
                    recipient_email = address
                    break

        if not recipient_email:
            speak(
                "Sorry, I could not find that person in your contacts. "
                "Try saying add contact to add them first!"
            )
            return

        speak(f"What is the subject of the email to {recipient_name}?")
        subject = listen(timeout=20)
        if not subject:
            speak("Sorry, I did not catch the subject!")
            return

        speak("What should the email say?")
        body = listen(timeout=30)
        if not body:
            speak("Sorry, I did not catch the message!")
            return

        speak(
            f"I will send an email to {recipient_name} "
            f"with subject: {subject}. "
            "Say yes to confirm or no to cancel."
        )
        confirmation = listen(timeout=10)

        if not confirmation or not any(
            w in confirmation for w in ["yes","send","go","okay","ok"]
        ):
            speak("Okay, email cancelled!")
            return

        msg            = MIMEMultipart()
        msg["From"]    = SENDER_EMAIL
        msg["To"]      = recipient_email
        msg["Subject"] = subject
        msg.attach(MIMEText(body, "plain"))

        with smtplib.SMTP("smtp.gmail.com", 587) as server:
            server.starttls()
            server.login(SENDER_EMAIL, SENDER_PASSWORD)
            server.sendmail(SENDER_EMAIL, recipient_email, msg.as_string())

        speak(f"Email sent to {recipient_name} successfully!")
        print(f"✅ Email sent to {recipient_email}")

    except smtplib.SMTPAuthenticationError:
        speak(
            "Authentication failed! Please check your Gmail address "
            "and App Password in the .env file."
        )
    except Exception as e:
        speak("Sorry, something went wrong with the email!")
        print(f"Email error: {e}")


